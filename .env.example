# ── database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://anvil:anvil@localhost:5432/anvil

# ── Hack Club Auth (HCA) — register at auth.hackclub.com/developer/apps ───
HCA_ISSUER=https://auth.hackclub.com
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=

# ── Hackatime (server-side admin key — no user OAuth needed) ──────────────
# authorizes identity lookups (/users/lookup_slack_uid, lookup_email) and
# per-user stats reads; accounts auto-link from HCA's slack id / email
HACKATIME_ADMIN_KEY=
# 1 = deterministic in-memory Hackatime fake (dev/tests)
HACKATIME_MOCK=0
# 1 = fake HCA profile for seeded dev users (no real tokens) — purchases/reveals work locally
HCA_MOCK=0

# ── Sidekick (review/fulfillment interface) ───────────────────────────────
SIDEKICK_SECRET=

# ── Unified YSWS DB (Airtable) ─────────────────────────────────────────────
AIRTABLE_ENABLED=0
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── screenshot/thumbnail storage (S3-compatible, e.g. Cloudflare R2) ──────
S3_ENDPOINT=
S3_BUCKET=anvil
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ── traction polling ───────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── misc ───────────────────────────────────────────────────────────────────
# openssl rand -hex 32
ENCRYPTION_MASTER_KEY=
PUBLIC_BASE_URL=http://localhost:5173

# where the "help" tab sends users (a Slack channel link)
HELP_SLACK_URL=https://hackclub.slack.com/archives/C0M8PUPU6

# incoming-webhook URL for the internal activity feed (new signups, projects,
# ships - ships @-ping all admins). unset = feed disabled.
# create one at https://api.slack.com/apps -> Incoming Webhooks
SLACK_FEED_WEBHOOK=

# bot token (xoxb-...) with chat:write for participant DMs (review outcomes,
# order updates) and channels:write/groups:write to auto-invite new signups
# into #anvil-bulletin/#anvil-help. unset = both disabled.
SLACK_BOT_TOKEN=
# override the Slack API base URL (dev only - point at a local catcher)
# SLACK_API_BASE=
